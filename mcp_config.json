{
  "description": "Configuration MCP pour les agents Snowflake Retail",
  "endpoint": {
    "url": "https://nfhtxdc-gg96899.snowflakecomputing.com/api/v2/databases/RETAIL_DEMO/schemas/PUBLIC/mcp-servers/retail_mcp_server",
    "pattern": "https://{account_URL}/api/v2/databases/{database}/schemas/{schema}/mcp-servers/{name}",
    "components": {
      "account_URL": "nfhtxdc-gg96899.snowflakecomputing.com",
      "database": "RETAIL_DEMO", 
      "schema": "PUBLIC",
      "mcp_server_name": "retail_mcp_server"
    }
  },
  "authentication": {
    "type": "snowflake",
    "role": "MCP_RETAIL_ROLE",
    "warehouse": "COMPUTE_WH",
    "required_credentials": [
      "SNOWFLAKE_USER",
      "SNOWFLAKE_PASSWORD",
      "SNOWFLAKE_ACCOUNT"
    ]
  },
  "tools": [
    {
      "name": "snowflake-retail-agent",
      "type": "CORTEX_AGENT_RUN",
      "description": "Agent IA retail français pour analyse clients, ventes et recommandations business",
      "identifier": "RETAIL_DEMO.PUBLIC.RETAIL_CLIENT_ADVISOR"
    },
    {
      "name": "retail-client-analysis", 
      "type": "GENERIC",
      "description": "Analyse intelligente des clients retail avec Cortex AI",
      "identifier": "RETAIL_DEMO.PUBLIC.AGENT_IA_CLIENTS"
    },
    {
      "name": "retail-backup-agent",
      "type": "GENERIC", 
      "description": "Agent de backup SQL pour questions clients (fallback si Cortex indisponible)",
      "identifier": "RETAIL_DEMO.PUBLIC.AGENT_CLIENTS"
    }
  ],
  "example_calls": {
    "json_rpc": {
      "jsonrpc": "2.0",
      "id": 1,
      "method": "tools/call",
      "params": {
        "name": "snowflake-retail-agent",
        "arguments": {
          "question": "Analysez les tendances ventes Q1 2026"
        }
      }
    },
    "claude_mcp_config": {
      "mcpServers": {
        "snowflake-retail": {
          "command": "mcp-client",
          "args": [
            "--endpoint", "https://nfhtxdc-gg96899.snowflakecomputing.com/api/v2/databases/RETAIL_DEMO/schemas/PUBLIC/mcp-servers/retail_mcp_server",
            "--auth", "snowflake",
            "--role", "MCP_RETAIL_ROLE",
            "--warehouse", "COMPUTE_WH"
          ]
        }
      }
    }
  }
}